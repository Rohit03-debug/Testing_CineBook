<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="CineBook Known Defect Screenshot Suite" verbose="1" parallel="false">
    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <parameter name="browser" value="chrome"/>
    <parameter name="headless" value="false"/>

    <test name="Known Defect Cases">
        <groups>
            <run>
                <include name="known-defect"/>
            </run>
        </groups>
        <packages>
            <package name="tests"/>
        </packages>
    </test>
</suite>
